# Copy to .env.local for local dev. On Vercel, set these as Project env vars.
# The anon key is safe to ship in the client bundle by design — Row-Level
# Security (supabase/rls.sql) is the actual access control.
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
